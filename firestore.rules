rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Owner-only access to everything under a user's document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
